@model GoogDocsLite.Client.Models.Documents.InvitesIndexViewModel
@{
    ViewData["Title"] = "Invites";
}

<section class="page-header">
    <div>
        <h1 class="page-title">Invites</h1>
        <p class="page-subtitle">Review incoming collaboration requests and decide what enters your workspace.</p>
    </div>
    <div class="page-actions">
        <a class="btn app-btn app-btn-outline" asp-controller="Documents" asp-action="Index">Back to Documents</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
{
    <div class="app-alert app-alert-success">
        <span>@Model.InfoMessage</span>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="app-alert app-alert-danger">
        <span>@Model.ErrorMessage</span>
    </div>
}

@if (Model.Invites.Count == 0)
{
    <div class="empty-state">
        <h5 class="mb-1">Inbox is clear</h5>
        <p class="mb-0">No pending invites right now.</p>
    </div>
}
else
{
    <section class="invite-grid">
        @foreach (var invite in Model.Invites)
        {
            var roleClass = invite.Role == "Editor" ? "role-editor" : "role-viewer";

            <article class="invite-card">
                <div class="d-flex justify-content-between gap-2 align-items-start">
                    <h5>@invite.DocumentTitle</h5>
                    <span class="role-pill @roleClass">@invite.Role</span>
                </div>

                <div class="invite-meta">
                    <div>From: @invite.CreatedByUserId</div>
                    <div>Expires: @invite.ExpiresAtUtc.ToLocalTime().ToString("g")</div>
                </div>

                <div class="doc-card-actions justify-content-start">
                    <form method="post" asp-controller="Documents" asp-action="AcceptInvite" asp-route-inviteId="@invite.InviteId">
                        <button type="submit" class="btn app-btn btn-sm">Accept</button>
                    </form>
                    <form method="post" asp-controller="Documents" asp-action="DeclineInvite" asp-route-inviteId="@invite.InviteId">
                        <button type="submit" class="btn app-btn app-btn-outline btn-sm">Decline</button>
                    </form>
                </div>
            </article>
        }
    </section>
}
