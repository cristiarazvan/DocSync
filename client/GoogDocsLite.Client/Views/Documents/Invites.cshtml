@model GoogDocsLite.Client.Models.Documents.InvitesIndexViewModel
@{
    ViewData["Title"] = "Incoming Invites";
}

<section class="app-page-head">
    <div>
        <h1 class="mb-1">Incoming Invites</h1>
        <p>Review collaboration invitations and decide what belongs in your workspace.</p>
    </div>
    <a class="btn app-btn app-btn-outline" asp-controller="Documents" asp-action="Index">Back to Documents</a>
</section>

@if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
{
    <div class="app-alert app-alert-success">@Model.InfoMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="app-alert app-alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Invites.Count == 0)
{
    <div class="empty-state">
        <h5 class="mb-1">Inbox is clean</h5>
        <p class="mb-0">You currently have no pending invites.</p>
    </div>
}
else
{
    <section class="doc-grid">
        @foreach (var invite in Model.Invites)
        {
            <article class="doc-card">
                <div>
                    <h5>@invite.DocumentTitle</h5>
                    <p class="doc-card-meta mb-0">Sent by @invite.CreatedByUserId</p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <span class="role-pill role-editor">@invite.Role</span>
                    <span class="role-pill role-viewer">Expires @invite.ExpiresAtUtc.ToLocalTime().ToString("g")</span>
                </div>

                <div class="doc-card-actions">
                    <form method="post" asp-controller="Documents" asp-action="AcceptInvite" asp-route-inviteId="@invite.InviteId">
                        <button type="submit" class="btn app-btn btn-sm">Accept</button>
                    </form>
                    <form method="post" asp-controller="Documents" asp-action="DeclineInvite" asp-route-inviteId="@invite.InviteId">
                        <button type="submit" class="btn app-btn app-btn-outline btn-sm">Decline</button>
                    </form>
                </div>
            </article>
        }
    </section>
}
