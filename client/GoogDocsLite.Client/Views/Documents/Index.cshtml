@model GoogDocsLite.Client.Models.Documents.DocumentsIndexViewModel
@using System.Linq
@{
    ViewData["Title"] = "Documents";

    var editableCount = Model.Documents.Count(x => x.AccessRole is "Owner" or "Editor");
}

<section class="workspace-hero">
    <div>
        <div class="eyebrow">Workspace</div>
        <h1 class="page-title">Documents</h1>
        <p class="page-subtitle">Create, open, and manage collaborative drafts from one focused view.</p>
    </div>
    <div class="page-actions">
        <a class="btn app-btn app-btn-outline" asp-controller="Documents" asp-action="Invites">
            Invites
            @if (Model.IncomingInvitesCount > 0)
            {
                <span class="inline-counter">@Model.IncomingInvitesCount</span>
            }
        </a>
        <button id="newDocumentButton" type="button" class="btn app-btn">New document</button>
    </div>
</section>

<div class="message-stack">
    @if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
    {
        <div class="app-alert app-alert-success">
            <span>@Model.InfoMessage</span>
        </div>
    }

    @if (Model.SyncedInvitesCount > 0)
    {
        <div class="app-alert app-alert-info">
            <span>Synced @Model.SyncedInvitesCount pending invite(s).</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert app-alert-danger">
            <span>@Model.ErrorMessage</span>
        </div>
    }
</div>

<section class="workspace-intro-card workspace-intro-card-single">
    <div class="workspace-compact-head">
        <div>
            <div class="eyebrow">Create</div>
            <h2>Start a new document</h2>
        </div>
        <div class="workspace-compact-stats">
            <span class="mini-note">@Model.Documents.Count total</span>
            <span class="mini-note">@editableCount editable</span>
            <span class="mini-note">@Model.IncomingInvitesCount invites</span>
        </div>
    </div>

    <form id="createDocumentForm" method="post" asp-controller="Documents" asp-action="Create" class="workspace-create-form">
        <div>
            <input id="createDocumentTitle" asp-for="CreateForm.Title" class="form-control" placeholder="e.g. Quarterly planning brief" />
            <span asp-validation-for="CreateForm.Title" class="text-danger d-block mt-2"></span>
        </div>
        <button type="submit" class="btn app-btn">Create</button>
    </form>
</section>

<nav class="filter-tabs" aria-label="Document filters">
    <a class="filter-tab @(Model.ActiveView == "owned" ? "is-active" : string.Empty)" asp-controller="Documents" asp-action="Index" asp-route-view="owned">Owned by me</a>
    <a class="filter-tab @(Model.ActiveView == "shared" ? "is-active" : string.Empty)" asp-controller="Documents" asp-action="Index" asp-route-view="shared">Shared with me</a>
    <a class="filter-tab @(Model.ActiveView == "all" ? "is-active" : string.Empty)" asp-controller="Documents" asp-action="Index" asp-route-view="all">All documents</a>
</nav>

@if (Model.Documents.Count == 0)
{
    <div class="empty-state empty-state-large">
        <div class="eyebrow">Nothing here yet</div>
        <h2>No documents in this view.</h2>
        <p>Create your first working draft and bring collaborators in when you are ready.</p>
        <button id="emptyNewDocumentButton" type="button" class="btn app-btn">Create document</button>
    </div>
}
else
{
    <section class="doc-grid">
        @foreach (var doc in Model.Documents)
        {
            var roleClass = doc.AccessRole == "Owner"
                ? "role-owner"
                : doc.AccessRole == "Editor"
                    ? "role-editor"
                    : "role-viewer";

            <article class="doc-card">
                <div class="doc-card-top">
                    <div>
                        <div class="card-kicker">Document</div>
                        <h2>@doc.Title</h2>
                    </div>
                    <span class="role-pill @roleClass">@doc.AccessRole</span>
                </div>

                <div class="doc-card-meta-grid">
                    <div>
                        <small>Last updated</small>
                        <strong>@doc.UpdatedAt.ToLocalTime().ToString("g")</strong>
                    </div>
                    <div>
                        <small>Ownership</small>
                        <strong>@(doc.IsOwner ? "Managed by you" : "Shared with you")</strong>
                    </div>
                </div>

                <div class="doc-card-actions">
                    @if (doc.IsOwner)
                    {
                        <form method="post" asp-controller="Documents" asp-action="Delete" asp-route-id="@doc.Id" class="m-0">
                            <button type="submit" class="btn app-btn app-btn-outline app-btn-danger btn-sm">Delete</button>
                        </form>
                    }
                    <a class="btn app-btn btn-sm" asp-controller="Documents" asp-action="Edit" asp-route-id="@doc.Id">Open editor</a>
                </div>
            </article>
        }
    </section>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const createInput = document.getElementById("createDocumentTitle");
            const createForm = document.getElementById("createDocumentForm");
            const newButtons = [
                document.getElementById("newDocumentButton"),
                document.getElementById("emptyNewDocumentButton")
            ].filter(Boolean);

            function focusCreateInput() {
                if (!createInput) {
                    return;
                }

                createInput.focus();
                createInput.select();
            }

            newButtons.forEach((button) => {
                button.addEventListener("click", focusCreateInput);
            });

            const query = new URLSearchParams(window.location.search);
            if (query.get("new") === "1") {
                focusCreateInput();
            }

            if (createForm) {
                createForm.addEventListener("submit", () => {
                    if (createInput) {
                        createInput.value = (createInput.value || "").trim();
                    }
                });
            }
        })();
    </script>
}
