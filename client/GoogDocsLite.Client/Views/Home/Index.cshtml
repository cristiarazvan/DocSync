@model GoogDocsLite.Client.Models.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
    var isSignedIn = User.Identity?.IsAuthenticated ?? false;
}

@if (!isSignedIn)
{
    <section class="hero-frame">
        <div class="hero-grid hero-grid-minimal">
            <div class="hero-copy">
                <div class="eyebrow">Collaborative editor</div>
                <h1 class="hero-title">Write together in a cleaner workspace.</h1>
                <p class="hero-lead">
                    DocSync keeps documents, invites, and live editing in one place without piling extra UI around the work.
                </p>

                <div class="hero-actions">
                    <a class="btn app-btn" asp-area="Identity" asp-page="/Account/Login">Try the app</a>
                    <a class="btn app-btn app-btn-outline" asp-area="Identity" asp-page="/Account/Register">Create account</a>
                </div>

                <div class="hero-inline-notes">
                    <span class="mini-note">Realtime editing</span>
                    <span class="mini-note">Owner / Editor / Viewer roles</span>
                    <span class="mini-note">Invites and sharing</span>
                </div>
            </div>

            <div class="hero-visual hero-visual-minimal" aria-hidden="true">
                <div class="doc-mockup-stack doc-mockup-stack-minimal">
                    <div class="doc-mockup doc-mockup-left"></div>
                    <div class="doc-mockup doc-mockup-center">
                        <span class="doc-mockup-tag">DocSync</span>
                        <div class="doc-mockup-lines">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="minimal-feature-strip">
        <article class="metric-card">
            <small>Roles</small>
            <strong>Owner, editor, viewer</strong>
        </article>
        <article class="metric-card">
            <small>Demo access</small>
            <strong>Seeded demo accounts ready</strong>
        </article>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert app-alert-danger">
            <span>@Model.ErrorMessage</span>
        </div>
    }
}
else
{
    <section class="dashboard-hero dashboard-hero-minimal">
        <div class="dashboard-hero-copy">
            <div class="eyebrow">Workspace</div>
            <h1 class="hero-title">Welcome back to DocSync.</h1>
            <p class="hero-lead">Open your documents or review invites. The rest stays out of the way.</p>
        </div>
        <div class="page-actions">
            <a class="btn app-btn" asp-controller="Documents" asp-action="Index">Open documents</a>
            <a class="btn app-btn app-btn-outline" asp-controller="Documents" asp-action="Invites">Review invites</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert app-alert-danger">
            <span>@Model.ErrorMessage</span>
        </div>
    }
}
