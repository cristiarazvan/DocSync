<!DOCTYPE html>
<html lang="en" data-theme="light">
@{
    var currentPath = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
    var isSignedIn = User.Identity?.IsAuthenticated ?? false;

    string NavClass(string target)
    {
        if (target == "/")
        {
            return currentPath == "/" ? "is-active" : string.Empty;
        }

        if (target == "/docs")
        {
            return currentPath == "/docs" ? "is-active" : string.Empty;
        }

        return currentPath.StartsWith(target) ? "is-active" : string.Empty;
    }
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DocSync</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GoogDocsLite.Client.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="site-shell">
        <div class="site-backdrop" aria-hidden="true">
            <div class="site-backdrop-grid"></div>
            <div class="site-backdrop-glow site-backdrop-glow-left"></div>
            <div class="site-backdrop-glow site-backdrop-glow-right"></div>
        </div>

        <header class="site-header">
            <div class="site-header-inner">
                <a class="site-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="site-brand-mark" aria-hidden="true">
                        <span></span>
                        <span></span>
                    </span>
                    <span class="site-brand-copy">
                        <strong>DocSync</strong>
                        <small>Structured collaboration for living documents</small>
                    </span>
                </a>

                <button id="mobileNavToggle" class="site-mobile-toggle" type="button" aria-controls="primaryNav" aria-expanded="false">
                    Navigation
                </button>

                <nav id="primaryNav" class="site-nav" aria-label="Primary">
                    <a class="site-nav-link @NavClass("/")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    @if (isSignedIn)
                    {
                        <a class="site-nav-link @NavClass("/docs")" asp-area="" asp-controller="Documents" asp-action="Index">Documents</a>
                        <a class="site-nav-link @NavClass("/docs/invites")" asp-area="" asp-controller="Documents" asp-action="Invites">Invites</a>
                    }
                </nav>

                <div class="site-header-actions">
                    <button id="themeToggleButton" type="button" class="theme-toggle" aria-label="Toggle color theme">
                        <span id="themeToggleLabel">Dark mode</span>
                    </button>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>

        <main role="main" class="site-main">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="site-footer-meta">
                <span>DocSync</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
