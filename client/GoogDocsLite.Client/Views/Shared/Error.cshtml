@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="section-frame policy-shell">
    <div class="section-heading">
        <div>
            <div class="eyebrow">System state</div>
            <h1 class="page-title">An error interrupted this request.</h1>
        </div>
        <p class="section-copy">
            The application could not complete the current action. Use the request identifier below for troubleshooting if needed.
        </p>
    </div>

    <div class="message-stack">
        <div class="app-alert app-alert-danger">
            <span>An error occurred while processing your request.</span>
        </div>
    </div>

    <div class="policy-grid">
        @if (Model.ShowRequestId)
        {
            <article class="editorial-card">
                <div class="card-kicker">Request ID</div>
                <h2><code>@Model.RequestId</code></h2>
                <p>Use this identifier when tracing logs or reproducing the failure.</p>
            </article>
        }

        <article class="editorial-card">
            <div class="card-kicker">Development mode</div>
            <h2>Detailed stack traces are only shown in the Development environment.</h2>
            <p>Do not enable Development in deployed environments because it can expose sensitive runtime information.</p>
        </article>
    </div>
</section>
