@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="auth-page">
    <section class="auth-shell">
        <div class="auth-card">
            <div class="eyebrow">Sign in</div>
            <h1>Try DocSync or return to your workspace.</h1>
            <p>Use your own account or one of the seeded roles below to test sharing, invites, and permissions.</p>

            <form id="account" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div>
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                </div>

                <button id="login-submit" type="submit" class="btn app-btn w-100">Log in</button>

                <div class="auth-links">
                    <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                </div>
            </form>
        </div>

        <aside class="auth-side auth-side-compact">
            <div class="auth-side-panel">
                <div class="eyebrow">Demo access</div>
                <h2>Seeded roles ready to use.</h2>
                <p>All demo accounts use password <strong>demo123</strong>. Use quick fill to test the app faster.</p>
            </div>

            <div class="demo-account-list">
                <button type="button" class="demo-account-card" data-demo-email="owner.demo@googdocs.local" data-demo-password="demo123">
                    <small>Owner</small>
                    <strong>owner.demo@googdocs.local</strong>
                </button>
                <button type="button" class="demo-account-card" data-demo-email="editor.demo@googdocs.local" data-demo-password="demo123">
                    <small>Editor</small>
                    <strong>editor.demo@googdocs.local</strong>
                </button>
                <button type="button" class="demo-account-card" data-demo-email="viewer.demo@googdocs.local" data-demo-password="demo123">
                    <small>Viewer</small>
                    <strong>viewer.demo@googdocs.local</strong>
                </button>
                <button type="button" class="demo-account-card" data-demo-email="outsider.demo@googdocs.local" data-demo-password="demo123">
                    <small>Outsider</small>
                    <strong>outsider.demo@googdocs.local</strong>
                </button>
            </div>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form auth-external">
                    <p class="mb-1">Use another provider</p>
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn app-btn app-btn-outline" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                    }
                </form>
            }
        </aside>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const emailInput = document.getElementById("Input_Email");
            const passwordInput = document.getElementById("Input_Password");
            const rememberMeInput = document.getElementById("Input_RememberMe");

            document.querySelectorAll("[data-demo-email]").forEach((button) => {
                button.addEventListener("click", () => {
                    if (emailInput) {
                        emailInput.value = button.getAttribute("data-demo-email") || "";
                    }

                    if (passwordInput) {
                        passwordInput.value = button.getAttribute("data-demo-password") || "";
                    }

                    if (rememberMeInput instanceof HTMLInputElement) {
                        rememberMeInput.checked = true;
                    }
                });
            });
        })();
    </script>
}
