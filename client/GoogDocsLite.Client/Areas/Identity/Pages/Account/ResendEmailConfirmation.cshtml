@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend email confirmation";
}

<div class="auth-page">
    <section class="auth-shell">
        <div class="auth-card">
            <div class="eyebrow">Verification</div>
            <h1>Resend confirmation email.</h1>
            <p>Enter your email address and the system will send a new confirmation link.</p>

            <form method="post" class="auth-form">
                <div asp-validation-summary="All" class="text-danger" role="alert"></div>

                <div>
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn app-btn w-100">Resend confirmation</button>

                <div class="auth-links">
                    <a asp-page="./Login">Back to login</a>
                </div>
            </form>
        </div>

        <aside class="auth-side">
            <div class="auth-side-panel">
                <div class="eyebrow">Protected access</div>
                <h2>Verification keeps account identity aligned with the workspace.</h2>
                <p>Confirm the address attached to your collaboration context before returning to editing.</p>
            </div>
        </aside>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
