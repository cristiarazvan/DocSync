@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="auth-page">
    <section class="auth-shell">
        <div class="auth-card">
            <h1>Reset password</h1>
            <p>Enter your account email and we will send a reset link.</p>

            <form method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div>
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn app-btn w-100">Send reset link</button>

                <div class="auth-links">
                    <a asp-page="./Login">Back to login</a>
                </div>
            </form>
        </div>

        <aside class="auth-side">
            <div>
                <h2>Account recovery</h2>
                <p>If your email exists, you'll receive reset instructions.</p>
            </div>
        </aside>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
